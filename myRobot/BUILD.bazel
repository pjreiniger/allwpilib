        "//wpimath:wpimath-java",

    ]
)

wpilib_cc_library(
    name="myRobot-cpp",
    deps=[
        "//hal:wpiHal-cpp",
        "//wpilibc:wpilibc-cpp",
        "//ntcore:ntcore-cpp",
        "//cscore:cscore-cpp",
        "//cameraserver:cameraserver-cpp",
        "//wpimath:wpimath-cpp",
    ],
    srcs=glob(["src/main/native/cpp/**/*.cpp"]),
    visibility=["//visibility:public"],
