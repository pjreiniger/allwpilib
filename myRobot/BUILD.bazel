
load("//bazel_scripts/rules:cc.bzl", "wpilib_cc_library")
load("//bazel_scripts/rules:java.bzl", "wpilib_java_library")

wpilib_java_library(
    name = "myRobot-java",
    deps = [
        "//hal:wpiHal-java",
        "//wpilibj:wpilibj",
        "//cameraserver:cameraserver-java",
        "//cscore:cscore-java",
